# ── Telegram Bot Configuration ────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather
BOT_USERNAME=YourBotUsername
BASESCAN_URL=https://sepolia.basescan.org/tx/
INITIAL_CREDITS=1.00
MAX_BUDGET_PER_QUERY=0.10

# ── Wallet Configuration (required for x402 payments) ─────────────────────
# Option 1: OpenFort TEE backend wallet (recommended)
OPENFORT_SECRET_KEY=sk_test_your_openfort_secret_key

# Option 2: Raw EVM private key (local dev only)
# EVM_PRIVATE_KEY=0x...

# ── Chain Configuration ────────────────────────────────────────────────────
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ── Optional: Override x402 service URLs ───────────────────────────────────
# FIRECRAWL_X402_URL=https://api.firecrawl.dev
# MINIFETCH_X402_URL=https://minifetch.com
# BLACKSWAN_X402_URL=https://x402.blackswan.wtf
# SLAMAI_X402_URL=https://api.slamai.dev
# ... (see serviceRegistry.ts for full list)
